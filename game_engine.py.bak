_CONFIG_FILE = None

def set_config_path(path):
    """Set config file path."""
    global _CONFIG_FILE
    _CONFIG_FILE = Path(path)

def _load_points_config() -> dict:
    """.
    
     points_config.yaml,.
    """
    global _CONFIG_FILE
    config_path = _CONFIG_FILE or (BASE_DIR / "points_config.yaml" if "BASE_DIR" in globals() else None)
    if config_path and config_path.exists():
        try:
            import yaml
            with open(config_path, "r", encoding="utf-8") as f:
                return yaml.safe_load(f)
        except ImportError:
            # pyyaml , pip 
            try:
                import subprocess
                subprocess.check_call(["pip", "install", "pyyaml", "-q"])
                import yaml
                with open(config_path, "r", encoding="utf-8") as f:
                    return yaml.safe_load(f)
            except Exception:
                return _get_default_config()
    return _get_default_config()

