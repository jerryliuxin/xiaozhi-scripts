# 
_loaded_config = None


def _load_points_config():
    """Load points_config.yaml. Return None if not found."""
    global _loaded_config
    if _loaded_config is not None:
        return _loaded_config
    _loaded_config = {}
    if not os.path.exists(POINTS_CONFIG_FILE):
        return None
    try:
        import yaml
        with open(POINTS_CONFIG_FILE, "r", encoding="utf-8") as f:
            _loaded_config = yaml.safe_load(f)
        return _loaded_config
    except ImportError:
        # PyYAML ,
        return _manual_parse_yaml(POINTS_CONFIG_FILE)
    except Exception:
        return None


def _manual_parse_yaml(path):
    """ YAML ( PyYAML ).
     config .
    """
    try:
        with open(path, "r", encoding="utf-8") as f:
            lines = f.readlines()
        result = {}
        current_section = None
        current_key = None
        for line in lines:
            stripped = line.strip()
            if not stripped or stripped.startswith("#"):
                continue
            if not line.startswith(" ") and line.endswith(":"):
                current_section = stripped[:-1]
                current_key = None
                result[current_section] = {}
            elif line.startswith("  ") and not line.startswith("    "):
                parts = stripped.split(":")
                key = parts[0].strip()
                val = ":".join(parts[1:]).strip()
                # 
                if " #" in val:
                    val = val[:val.index(" #")].strip()
                current_key = key
                if val:
                    # 
                    try:
                        val = int(val)
                    except (ValueError, TypeError):
                        try:
                            val = float(val)
                        except (ValueError, TypeError):
                            pass
                result[current_section][key] = val
            elif line.startswith("    ") and current_section and current_key:
                parts = stripped.split(":")
                key = parts[0].strip()
                val = ":".join(parts[1:]).strip()
                if " #" in val:
                    val = val[:val.index(" #")].strip()
                if isinstance(result[current_section].get(current_key), dict):
                    try:
                        val = int(val)
                    except (ValueError, TypeError):
                        try:
                            val = float(val)
                        except (ValueError, TypeError):
                            pass
                    result[current_section][current_key][key] = val
        return result
    except Exception:
        return {}


def _get_points_config():
    """, yaml ."""
    cfg = _load_points_config()
    if cfg is None:
        return None
    return cfg.get("activities", {})


def _get_streak_bonuses_config():
    """, yaml ."""
    cfg = _load_points_config()
    if cfg is None:
        return dict(_DEFAULT_STREAK_BONUSES)
    return cfg.get("streak_bonuses", dict(_DEFAULT_STREAK_BONUSES))


def _get_daily_complete_config():
    """."""
    cfg = _load_points_config()
    if cfg is None:
        return _DEFAULT_DAILY_COMPLETE_BONUS
    daily = cfg.get("daily_complete", {})
    return daily.get("points", _DEFAULT_DAILY_COMPLETE_BONUS)


def _get_required_activities():
    """."""
    cfg = _load_points_config()
    if cfg is None:
        return ["unlock", "english_quiz", "math_logic", "chinese_recite", "speech_practice"]
    daily = cfg.get("daily_complete", {})
    return daily.get("required_activities", ["unlock", "english_quiz", "math_logic", "chinese_recite", "speech_practice"])


