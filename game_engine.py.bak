# 
CONFIG = _load_points_config()

def get_activity_points(activity_type: str) -> int:
    """."""
    act = CONFIG.get("activities", {})
    entry = act.get(activity_type, {})
    return entry.get("points", 0)

def get_daily_limit(activity_type: str) -> int:
    """."""
    act = CONFIG.get("activities", {})
    entry = act.get(activity_type, {})
    return entry.get("daily_limit", 999)

def get_streak_bonuses() -> dict:
    """."""
    return CONFIG.get("streak_bonuses", {3: 5, 7: 10, 14: 15, 30: 20})

def get_multi_bonus_thresholds() -> dict:
    """."""
    return CONFIG.get("multi_bonus_thresholds", {3: 10, 4: 20, 5: 30})

def get_daily_complete_config() -> dict:
    """."""
    return CONFIG.get("daily_complete", {"points": 30, "required_activities": []})

def get_penalty_multiplier(missed_days: int) -> float:
    """."""
    pm = CONFIG.get("penalty_multiplier", {})
    for days in sorted(pm.keys()):
        if missed_days >= days:
            return pm[days]
    return 1.0  # 


"""Small intelligence education scoring system -- reward/penalty engine.

Core features:
1. Multi-dimensional scoring (study/household/positive behavior/quizzes)
2. Daily task system (required + optional)
3. Streak reward/penalty (decay on break + increment on streak)
4. Chore tracking
5. Daily quiz
6. Reward shop (score redemption)
7. Achievement badges
8. Level system
"""

import logging

logger = logging.getLogger("xiaozhi_edu")
if not logger.handlers:
    handler = logging.StreamHandler()
    handler.setFormatter(logging.Formatter("%(asctime)s [%(levelname)s] %(name)s: %(message)s"))
    logger.addHandler(handler)
    logger.setLevel(logging.WARNING)

